# API secret for backend authorization (sent as Authorization: Bearer <value>).
# Example: n8n-secret or your backend secret. Required when using real backend (USE_MOCK_DATA=false).
VITE_API_SECRET=

# Production API base URL (required when frontend is on HTTPS, e.g. Vercel). Must be HTTPS to avoid mixed-content blocking.
# Example: https://wellington.aibolt.ai
VITE_API_BASE_URL=https://api.aibolt.ai
